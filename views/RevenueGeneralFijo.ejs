<link rel="stylesheet" href="css/rwd-table.min.css">
<link rel="stylesheet" href="css/revenue-table.css">
<link rel="stylesheet" href="https://cdn.datatables.net/2.1.6/css/dataTables.dataTables.css">
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.1.2/css/buttons.dataTables.css">

<div class="revenue-page">
  <div class="revenue-hero">
    <div class="d-flex flex-wrap justify-content-between align-items-end gap-3">
      <div>
        <p class="revenue-hero-eyebrow mb-1">Revenue · Fijo</p>
        <h1 class="h3 mb-1">Mes trabajado: <%= mes %> <%= anio %></h1>
        <% if (user) { %>
          <span class="badge bg-light text-dark"><i class="bi bi-person-check me-1"></i><%= user.nombre %></span>
        <% } %>
      </div>
      <a href="/revenueMenuFijo" class="btn btn-light btn-lg">
        <i class="bi bi-arrow-left-short"></i> Menú revenue fijo
      </a>
    </div>
  </div>

  <div class="revenue-table-card revenue-dt-wrap">
    <table id="example" class="table table-hover align-middle w-100 nowrap mb-0 revenue-table">
        <thead>
          <tr>
            <th>Acciones</th>
            <th>Nº venta</th>
            <th>Celular</th>
            <th>Abonado</th>
            <th>Trámite</th>
            <th>Ciclo fact.</th>
            <th>F1</th>
            <th>F2</th>
            <th>F3</th>
            <th>F4</th>
            <th>F5</th>
            <th>F6</th>
            <th>Vendedor</th>
            <th>Instalada</th>
            <th>Estado</th>
          </tr>
        </thead>
        <tbody>
          <% results.forEach((sale)=> { %>
            <tr>
              <td>
                <a href="/editRevFijo/<%= mes %>/<%= anio %>/<%= sale.SaleId %>" class="btn btn-primary btn-sm revenue-btn-edit">
                  <i class="bi bi-pencil-square"></i> Editar
                </a>
              </td>
              <td><span class="revenue-id"><%= sale.SaleId %></span></td>
              <td><%= sale.Celular_Tramite %></td>
              <td><%= sale.Numero_Abonado %></td>
              <td><small class="text-muted"><%= sale.Tipo_Tramite %></small></td>
              <td>
                <% if (sale.Ciclo_Facturacion) { %>
                  <span class="badge rounded-pill bg-dark"><%= sale.Ciclo_Facturacion %></span>
                <% } else { %>
                  <span class="text-muted">—</span>
                <% } %>
              </td>
              <td><%- include('partials/revenueFacturaValue', { value: sale.Factura_1 }) %></td>
              <td><%- include('partials/revenueFacturaValue', { value: sale.Factura_2 }) %></td>
              <td><%- include('partials/revenueFacturaValue', { value: sale.Factura_3 }) %></td>
              <td><%- include('partials/revenueFacturaValue', { value: sale.Factura_4 }) %></td>
              <td><%- include('partials/revenueFacturaValue', { value: sale.Factura_5 }) %></td>
              <td><%- include('partials/revenueFacturaValue', { value: sale.Factura_6 }) %></td>
              <td><small><%= sale.Nombre_Vendedor %></small></td>
              <td>
                <% if (sale.Instalada === 'Instalada') { %>
                  <span class="badge text-bg-success rounded-pill"><%= sale.Instalada %></span>
                <% } else if (sale.Instalada === 'No Instalada') { %>
                  <span class="badge text-bg-warning text-dark rounded-pill"><%= sale.Instalada %></span>
                <% } else { %>
                  <span class="badge text-bg-secondary rounded-pill"><%= sale.Instalada %></span>
                <% } %>
              </td>
              <td><small class="text-secondary"><%= sale.Estados %></small></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.js"></script>
<script src="https://cdn.datatables.net/2.1.6/js/dataTables.js"></script>
<script src="https://cdn.datatables.net/buttons/3.1.2/js/dataTables.buttons.js"></script>
<script src="https://cdn.datatables.net/buttons/3.1.2/js/buttons.dataTables.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
<script src="https://cdn.datatables.net/buttons/3.1.2/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/3.1.2/js/buttons.print.min.js"></script>

<script>
  new DataTable('#example', {
    scrollX: true,
    pageLength: 25,
    order: [[1, 'desc']],
    language: {
      search: 'Buscar:',
      lengthMenu: 'Mostrar _MENU_ filas',
      info: '_START_–_END_ de _TOTAL_',
      infoEmpty: 'Sin filas',
      infoFiltered: '(filtrado de _MAX_)',
      zeroRecords: 'Sin coincidencias',
      emptyTable: 'No hay ventas para este mes.',
      paginate: { first: '«', previous: '‹', next: '›', last: '»' }
    },
    layout: {
      topStart: { buttons: ['copy', 'csv', 'excel', 'pdf', 'print'] }
    }
  });
</script>
